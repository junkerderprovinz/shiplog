<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
  <!ENTITY name      "ShipLog">
  <!ENTITY slug      "shiplog">
  <!ENTITY author    "junkerderprovinz">
  <!ENTITY version   "1.0.4">
  <!ENTITY launch    "Settings/ShipLog">
  <!ENTITY gitURL    "https://raw.githubusercontent.com/junkerderprovinz/shiplog/main/plugin">
  <!ENTITY pluginURL "&gitURL;/&slug;.plg">
  <!ENTITY pkgURL    "https://github.com/junkerderprovinz/shiplog/releases/download/v&version;">
  <!ENTITY emhttp    "/usr/local/emhttp/plugins/&slug;">
  <!ENTITY plgPath   "/boot/config/plugins/&slug;">
  <!ENTITY txz       "&slug;-&version;-x86_64-1.txz">
]>

<PLUGIN name="&name;"
        author="&author;"
        version="&version;"
        launch="&launch;"
        pluginURL="&pluginURL;"
        icon="anchor"
        min="6.10.0"
        support="https://forums.unraid.net/topic/199510-support-junkerderprovinz-shiplog/">

<CHANGES>
Shows the changelog of your installed Docker containers, right in the Docker tab:
what changed from your running image to the newest, with a risk badge. Read-only —
optional AI summaries (Ollama) and Matrix alerts.

### 1.0.4
- Remembers the running version per container. A rolling ":latest" image is
  pinned to a real version once its digest matches the newest release, then
  carried forward — so a later update shows a true "1.7 -> 1.8" instead of
  "latest". The newest version is proven by digest, so a :latest that lags a
  newer published tag is never mislabeled.
- The bubble header now shows the remembered version as the current one.

### 1.0.3
- Resolve changelogs for ghcr.io images even without an OCI source label
  (ghcr.io/owner/repo → github.com/owner/repo), so more containers get a
  changelog + version instead of an empty "latest".
- Installer now force-reinstalls the package (upgradepkg --reinstall), fixing
  the "newer version already installed" skip when coming from the old
  date-versioned test builds.

### 1.0.2
- For an up-to-date ":latest" container, the header now shows the resolved
  version number (e.g. "1.8.0") instead of "latest".

### 1.0.1
- Release date in the bubble is now formatted DD.MM.YYYY.

### 1.0.0
- A changelog control next to every container in Unraid's native Docker tab: the
  version jump, a deterministic risk badge, the release notes, and a DEPRECATED
  badge when the upstream repo is archived. Up-to-date containers show the notes
  of the version they're running.
- Optional AI summaries via a local Ollama and Matrix notifications on new
  updates — each with a live "Check" button in the settings.
- Read-only by construction (read-only Docker socket); the engine runs as a host
  daemon, no separate container.
- Card settings page; the bubble follows Unraid's light/dark theme and language.
</CHANGES>

<!--
  The package (engine binary + plugin files) is built by plugin/pkg_build.sh and
  attached to the GitHub release "v&version;". SHA256 is injected at release.
-->
<FILE Name="&plgPath;/&txz;" Run="/sbin/upgradepkg --install-new --reinstall">
  <URL>&pkgURL;/&txz;</URL>
  <SHA256>d575a07df75fa6d580d8a5543cbd20494ad22143c47c4c505b34352b301c32a2</SHA256>
</FILE>

<!-- Post-install: (re)start the engine daemon immediately, no reboot needed. -->
<FILE Run="/bin/bash">
<INLINE>
chmod +x &emhttp;/bin/shiplog &emhttp;/scripts/rc.shiplog &emhttp;/event/* 2>/dev/null
&emhttp;/scripts/rc.shiplog restart
echo ""
echo "ShipLog &version; installed — open Settings &gt; ShipLog, or the Docker tab."
</INLINE>
</FILE>

<!-- Remove: stop the daemon, drop the package + files, keep user data + cfg. -->
<REMOVE>
<INLINE>
&emhttp;/scripts/rc.shiplog stop 2>/dev/null
removepkg &slug; 2>/dev/null
rm -rf &emhttp;
rm -f &plgPath;/*.txz
echo "ShipLog removed (appdata + settings kept)."
</INLINE>
</REMOVE>

</PLUGIN>
