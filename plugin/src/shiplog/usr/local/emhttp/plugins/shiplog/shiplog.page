<?php
/* ShipLog settings → writes /boot/config/plugins/shiplog/shiplog.cfg via Unraid's
   /update.php, then restarts the daemon. NB: no functions defined in a .page
   (Unraid may include it more than once → "Cannot redeclare" → blank page). */
$cfg    = parse_plugin_cfg("shiplog");
$enable = isset($cfg['ENABLE']) ? $cfg['ENABLE'] : 'true';
$port   = !empty($cfg['PORT'])          ? $cfg['PORT']          : '8484';
$ddir   = !empty($cfg['DATA_DIR'])      ? $cfg['DATA_DIR']      : '/mnt/user/appdata/shiplog';
$poll   = !empty($cfg['POLL_INTERVAL']) ? $cfg['POLL_INTERVAL'] : '6h';
$ghtok  = isset($cfg['GITHUB_TOKEN'])      ? $cfg['GITHUB_TOKEN']      : '';
$dhuser = isset($cfg['DOCKERHUB_USERNAME']) ? $cfg['DOCKERHUB_USERNAME'] : '';
$dhtok  = isset($cfg['DOCKERHUB_TOKEN'])    ? $cfg['DOCKERHUB_TOKEN']    : '';
$ourl   = isset($cfg['OLLAMA_URL'])        ? $cfg['OLLAMA_URL']        : '';
$omodel = isset($cfg['OLLAMA_MODEL'])      ? $cfg['OLLAMA_MODEL']      : '';
$mhs    = isset($cfg['MATRIX_HOMESERVER']) ? $cfg['MATRIX_HOMESERVER'] : '';
$mtok   = isset($cfg['MATRIX_TOKEN'])      ? $cfg['MATRIX_TOKEN']      : '';
$mroom  = isset($cfg['MATRIX_ROOM'])       ? $cfg['MATRIX_ROOM']       : '';
$confirm= isset($cfg['CONFIRM_UPDATE'])    ? $cfg['CONFIRM_UPDATE']    : 'true';   // ask before updating (default on)
$silent = isset($cfg['SILENT_UPDATE'])     ? $cfg['SILENT_UPDATE']     : 'false';  // suppress Unraid's update pop-up (default off)
/* Scheduled SemVer-gated auto-update (all default off/safe). */
$auEn    = (isset($cfg['AUTOUPDATE_ENABLED']) && $cfg['AUTOUPDATE_ENABLED']==='true');
$auLevel = isset($cfg['AUTOUPDATE_LEVEL'])     ? $cfg['AUTOUPDATE_LEVEL']     : 'off';
$auDigest= (isset($cfg['AUTOUPDATE_DIGEST'])  && $cfg['AUTOUPDATE_DIGEST']==='true');
$auDry   = (isset($cfg['AUTOUPDATE_DRYRUN'])  && $cfg['AUTOUPDATE_DRYRUN']==='true');
$auMode  = !empty($cfg['AUTOUPDATE_SCHED_MODE'])  ? $cfg['AUTOUPDATE_SCHED_MODE']  : 'off';
$auTime  = !empty($cfg['AUTOUPDATE_SCHED_TIME'])  ? $cfg['AUTOUPDATE_SCHED_TIME']  : '04:00';
$auEvery = !empty($cfg['AUTOUPDATE_SCHED_EVERY']) ? $cfg['AUTOUPDATE_SCHED_EVERY'] : '6';
/* CA Auto Update coexistence: warn so the user doesn't run both. */
$caPresent = is_dir('/usr/local/emhttp/plugins/ca.update.applications') || is_dir('/boot/config/plugins/ca.update.applications');

/* On/Off label in the active Unraid language (no function defs in a .page). */
$lang = strtolower(substr((string)(isset($_SESSION['locale']) ? $_SESSION['locale'] : ''), 0, 2));
$onoff = array(
  'en'=>array('On','Off'),   'de'=>array('Ein','Aus'),   'nl'=>array('Aan','Uit'),
  'fr'=>array('Activé','Désactivé'), 'es'=>array('Activado','Desactivado'),
  'it'=>array('Attivo','Disattivo'), 'pt'=>array('Ligado','Desligado'),
  'ru'=>array('Вкл','Выкл'), 'uk'=>array('Увімк','Вимк'), 'bg'=>array('Вкл','Изкл'),
  'pl'=>array('Wł.','Wył.'), 'cs'=>array('Zap.','Vyp.'),
  'sv'=>array('På','Av'),    'da'=>array('Til','Fra'),    'no'=>array('På','Av'), 'nb'=>array('På','Av'),
  'fi'=>array('Päällä','Pois'), 'hu'=>array('Be','Ki'),   'ro'=>array('Pornit','Oprit'),
  'tr'=>array('Açık','Kapalı'), 'el'=>array('Ενεργό','Ανενεργό'),
  'zh'=>array('开','关'),     'ja'=>array('オン','オフ'),  'ko'=>array('켜짐','꺼짐'),
);
$lbl   = isset($onoff[$lang]) ? $onoff[$lang] : $onoff['en'];
$onTxt = $lbl[0]; $offTxt = $lbl[1];

/* All other UI text follows Unraid's language too — load this plugin's locale file
   (English base, then overlay the active language; missing keys fall back to English). */
$langdir = '/usr/local/emhttp/plugins/shiplog/lang';
$L = json_decode(@file_get_contents("$langdir/en.json"), true) ?: array();
if ($lang !== 'en' && is_file("$langdir/$lang.json")) {
  $tr = json_decode(@file_get_contents("$langdir/$lang.json"), true);
  if (is_array($tr)) $L = array_merge($L, $tr);
}

/* Best-effort LAN IP for the status-page link — works even when the GUI is opened
   via the myunraid.net hostname, where location.hostname can't reach :PORT. */
$lanip = '';
$net = '/var/local/emhttp/network.ini';
if (is_file($net) && preg_match('/IPADDR(?::0)?\s*=\s*"?([0-9.]+)/', file_get_contents($net), $mip)) $lanip = $mip[1];
if ($lanip === '' && !empty($_SERVER['SERVER_ADDR'])) $lanip = $_SERVER['SERVER_ADDR'];
?>

