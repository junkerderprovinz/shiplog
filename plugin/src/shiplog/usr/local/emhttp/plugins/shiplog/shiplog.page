        <button type="button" class="sl-btn" onclick="slCheckOllama()"><?=$L['s_check']?></button>
        <span id="sl-ollama-result" class="sl-res"></span></div></div>
    </div>

    <div class="sl-card" data-tab="notify">
      <h3><?=$L['s_notif']?> <small><?=$L['s_notif_sub']?></small></h3>
      <div class="sl-row"><label><?=$L['s_mx_home']?></label><div class="sl-in">
        <input type="text" name="MATRIX_HOMESERVER" value="<?=htmlspecialchars($mhs)?>" placeholder="https://matrix.example.com"></div></div>
      <div class="sl-row"><label><?=$L['s_mx_token']?></label><div class="sl-in">
        <input type="password" id="sl-MATRIX_TOKEN" name="MATRIX_TOKEN" value="<?=htmlspecialchars($mtok)?>">
        <button type="button" class="sl-btn sl-eye" onclick="slToggle('sl-MATRIX_TOKEN',this)"><?=$L['s_show']?></button></div></div>
      <div class="sl-row"><label><?=$L['s_mx_room']?></label><div class="sl-in">
        <input type="text" name="MATRIX_ROOM" value="<?=htmlspecialchars($mroom)?>" placeholder="!roomid:server  or  #alias:server">
        <button type="button" class="sl-btn" onclick="slCheckMatrix()"><?=$L['s_check']?></button>
        <span id="sl-matrix-result" class="sl-res"></span></div></div>
    </div>

    <div class="sl-actions">
      <input type="submit" name="#apply" class="sl-btn sl-primary" value="<?=htmlspecialchars($L['s_apply'])?>">
      <input type="button" class="sl-btn" value="<?=htmlspecialchars($L['s_done'])?>" onclick="done()">
    </div>
  </form>
</div>

<script>
var SLT = <?=json_encode($L, JSON_UNESCAPED_UNICODE)?>;
var SL_ON = <?=json_encode($onTxt)?>, SL_OFF = <?=json_encode($offTxt)?>;
(function () {
  var port = "<?=htmlspecialchars($port)?>";
  var host = <?=json_encode($lanip)?> || location.hostname;
  var a = document.getElementById("sl-statuslink");
  if (!a) return;
  a.innerHTML = '<span class="sl-res run">' + SLT.s_checking + '</span>';
  fetch("/plugins/shiplog/server/status.php", { headers: { Accept: "application/json" } })
    .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }, function () { return { ok: false, d: null }; }); })
    .then(function (res) {
      if (res.ok && Array.isArray(res.d)) {
        var n = res.d.length;
        a.innerHTML = '<span class="sl-res ok">' + SLT.s_running.replace('%n', n) + '</span>' +
          ' <span class="sl-hint">' + SLT.s_statuspage + ' <a href="http://' + host + ':' + port + '/" target="_blank" rel="noopener">' + SLT.s_open + '</a></span>';
      } else {
        a.innerHTML = '<span class="sl-res err">' + SLT.s_unreachable + '</span> <span class="sl-hint">' + SLT.s_unreachable_hint + '</span>';
      }
    })
    .catch(function () { a.innerHTML = '<span class="sl-res err">' + SLT.s_unreachable + '</span>'; });
})();
function slEnable(cb) {
  document.getElementById('sl-enable').value = cb.checked ? 'true' : 'false';
  document.getElementById('sl-enable-state').textContent = cb.checked ? SL_ON : SL_OFF;
  slFire(document.getElementById('sl-enable'));
}
// generic on/off switch: sets the hidden field + its label, then un-greys Apply
function slSwitch(cb, hiddenId, stateId) {
  document.getElementById(hiddenId).value = cb.checked ? 'true' : 'false';
  document.getElementById(stateId).textContent = cb.checked ? SL_ON : SL_OFF;
  slFire(document.getElementById(hiddenId));
}
// Unraid only un-greys Apply when a field fires change/input. A programmatic
// value change (autodetect, the toggle's hidden field) must announce itself.
function slFire(el) {
  if (!el) return;
  el.dispatchEvent(new Event('input', { bubbles: true }));
  el.dispatchEvent(new Event('change', { bubbles: true }));
}
function slCheck(elId, url) {
  var out = document.getElementById(elId);
  out.className = 'sl-res run'; out.textContent = SLT.s_check + '…';
  fetch(url)
    .then(function (r) { return r.json(); })
    .then(function (d) { out.className = 'sl-res ' + (d.ok ? 'ok' : 'err'); out.textContent = (d.ok ? '✓ ' : '✗ ') + d.message; })
    .catch(function (e) { out.className = 'sl-res err'; out.textContent = '✗ ' + e; });
}
function slVal(n) { return (document.querySelector('[name=' + n + ']') || {}).value || ''; }
function slToggle(id, btn) {
  var i = document.getElementById(id);
  if (!i) return;
  if (i.type === 'password') { i.type = 'text'; btn.textContent = SLT.s_hide; }
  else { i.type = 'password'; btn.textContent = SLT.s_show; }
}
function slCheckDockerHub() {
  slCheck('sl-dh-result', '/plugins/shiplog/server/dockerhub-check.php?user=' +
    encodeURIComponent(slVal('DOCKERHUB_USERNAME')) + '&token=' + encodeURIComponent(slVal('DOCKERHUB_TOKEN')));
}
function slCheckOllama() {
  slCheck('sl-ollama-result', '/plugins/shiplog/server/ollama-check.php?url=' +
    encodeURIComponent(slVal('OLLAMA_URL')) + '&model=' + encodeURIComponent(slVal('OLLAMA_MODEL')));
}
function slCheckMatrix() {
  slCheck('sl-matrix-result', '/plugins/shiplog/server/matrix-check.php?hs=' +
    encodeURIComponent(slVal('MATRIX_HOMESERVER')) + '&token=' + encodeURIComponent(slVal('MATRIX_TOKEN')) +
    '&room=' + encodeURIComponent(slVal('MATRIX_ROOM')));
}
function slCheckGitHub() {
  slCheck('sl-gh-result', '/plugins/shiplog/server/github-check.php?token=' + encodeURIComponent(slVal('GITHUB_TOKEN')));
}
function slDetectOllama() {
  var out = document.getElementById('sl-ollama-result');
  out.className = 'sl-res run'; out.textContent = 'Detecting…';
  fetch('/plugins/shiplog/server/ollama-detect.php?url=' + encodeURIComponent(slVal('OLLAMA_URL')))
    .then(function (r) { return r.json(); })
    .then(function (d) {
      out.className = 'sl-res ' + (d.ok ? 'ok' : 'err');
      out.textContent = (d.ok ? '✓ ' : '✗ ') + d.message;
      if (d.ok && d.url) {
        var u = document.querySelector('[name=OLLAMA_URL]'); if (u) { u.value = d.url; slFire(u); }
        var m = document.querySelector('[name=OLLAMA_MODEL]'); if (m && !m.value && d.models && d.models.length) { m.value = d.models[0]; slFire(m); }
      }
    })
    .catch(function (e) { out.className = 'sl-res err'; out.textContent = '✗ ' + e; });
}
// Settings tabs (CC-style): show only the active tab's cards.
(function () {
  var tabs = document.querySelectorAll('#sl-tabs .sl-tab');
  var cards = document.querySelectorAll('.sl-card[data-tab]');
  function show(name) {
    tabs.forEach(function (t) { t.classList.toggle('active', t.getAttribute('data-go') === name); });
    cards.forEach(function (c) { c.setAttribute('data-hidden', c.getAttribute('data-tab') === name ? '0' : '1'); });
  }
  tabs.forEach(function (t) { t.addEventListener('click', function () { show(t.getAttribute('data-go')); }); });
  show('general');
})();
// Auto-update schedule: show the time input for "daily", the interval for hours/days.
function slAuMode() {
  var m = (document.getElementById('sl-au-mode') || {}).value;
  var t = document.getElementById('sl-au-time'), e = document.getElementById('sl-au-every'), u = document.getElementById('sl-au-every-unit');
  if (t) t.style.display = (m === 'daily') ? '' : 'none';
  if (e) e.style.display = (m === 'hours' || m === 'days') ? '' : 'none';
  if (u) u.textContent = m === 'hours' ? (SLT.s_au_unit_hours || '') : (m === 'days' ? (SLT.s_au_unit_days || '') : '');
}
slAuMode();
// Info icons (CC convention): move each field's help text (.sl-help inline hints
// + .sl-desc toggle descriptions) into a small ⓘ next to its label. The bubble
// renders the original HTML, so the GitHub/Docker-Hub token links stay clickable;
// it stays open while the pointer is over it. Graceful: if this never runs, the
// original help text remains visible.
(function () {
  var ICON = '<svg viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="7.1" fill="none" stroke="currentColor" stroke-width="1.2"/><circle cx="8" cy="4.7" r="1.05" fill="currentColor"/><rect x="7.05" y="6.8" width="1.9" height="5" rx=".95" fill="currentColor"/></svg>';
  var pop = null, hideT = null;
  function bubble() {
    if (pop) return pop;
    pop = document.createElement('div'); pop.className = 'sl-info-pop'; pop.style.display = 'none';
    pop.addEventListener('mouseenter', function () { clearTimeout(hideT); });
    pop.addEventListener('mouseleave', hideSoon);
    document.body.appendChild(pop);
    return pop;
  }
  function hideSoon() { clearTimeout(hideT); hideT = setTimeout(function () { if (pop) pop.style.display = 'none'; }, 150); }
  function show(icon) {
    clearTimeout(hideT);
    var p = bubble(); p.innerHTML = icon.getAttribute('data-html') || '';
    p.style.display = 'block'; p.style.visibility = 'hidden'; p.style.left = '0'; p.style.top = '0';
    var r = icon.getBoundingClientRect(), pw = p.offsetWidth, ph = p.offsetHeight;
    var vw = document.documentElement.clientWidth, vh = document.documentElement.clientHeight;
    var left = Math.max(8, Math.min(r.left + window.scrollX, window.scrollX + vw - pw - 8));
    var top = (r.bottom + ph + 14 > vh) ? (r.top + window.scrollY - ph - 7) : (r.bottom + window.scrollY + 7);
    p.style.left = left + 'px'; p.style.top = top + 'px'; p.style.visibility = 'visible';
  }
  try {
    document.querySelectorAll('.sl-help, .sl-desc').forEach(function (h) {
      var html = (h.innerHTML || '').trim(); if (!html) return;
      var row = h.closest('.sl-row'); if (!row) return;
      var label = row.querySelector('label'); if (!label) return;
      var icon = document.createElement('span');
      icon.className = 'sl-info'; icon.setAttribute('tabindex', '0'); icon.setAttribute('role', 'img');
      icon.setAttribute('aria-label', (h.textContent || '').trim());
      icon.setAttribute('data-html', html);
      icon.innerHTML = ICON;
      icon.addEventListener('mouseenter', function () { show(icon); });
      icon.addEventListener('mouseleave', hideSoon);
      icon.addEventListener('focus', function () { show(icon); });
      icon.addEventListener('blur', hideSoon);
      icon.addEventListener('click', function (e) { e.preventDefault(); show(icon); });
      icon.addEventListener('keydown', function (e) { if (e.key === 'Escape' && pop) { pop.style.display = 'none'; icon.blur(); } });
      label.appendChild(icon);
      if (h.parentNode) h.parentNode.removeChild(h);
    });
  } catch (e) { /* leave the help text visible on any failure */ }
})();
</script>
