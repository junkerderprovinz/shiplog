Menu="Utilities"
Title="ShipLog"
Icon="shiplog.png"
---
<?php
/* ShipLog settings → writes /boot/config/plugins/shiplog/shiplog.cfg via Unraid's
   /update.php, then restarts the daemon. NB: no functions defined in a .page
   (Unraid may include it more than once → "Cannot redeclare" → blank page). */
$cfg    = parse_plugin_cfg("shiplog");
$enable = isset($cfg['ENABLE']) ? $cfg['ENABLE'] : 'true';
$port   = !empty($cfg['PORT'])          ? $cfg['PORT']          : '8484';
$ddir   = !empty($cfg['DATA_DIR'])      ? $cfg['DATA_DIR']      : '/mnt/user/appdata/shiplog';
$poll   = !empty($cfg['POLL_INTERVAL']) ? $cfg['POLL_INTERVAL'] : '6h';
$ghtok  = isset($cfg['GITHUB_TOKEN'])      ? $cfg['GITHUB_TOKEN']      : '';
$dhuser = isset($cfg['DOCKERHUB_USERNAME']) ? $cfg['DOCKERHUB_USERNAME'] : '';
$dhtok  = isset($cfg['DOCKERHUB_TOKEN'])    ? $cfg['DOCKERHUB_TOKEN']    : '';
$ourl   = isset($cfg['OLLAMA_URL'])        ? $cfg['OLLAMA_URL']        : '';
$omodel = isset($cfg['OLLAMA_MODEL'])      ? $cfg['OLLAMA_MODEL']      : '';
$mhs    = isset($cfg['MATRIX_HOMESERVER']) ? $cfg['MATRIX_HOMESERVER'] : '';
$mtok   = isset($cfg['MATRIX_TOKEN'])      ? $cfg['MATRIX_TOKEN']      : '';
$mroom  = isset($cfg['MATRIX_ROOM'])       ? $cfg['MATRIX_ROOM']       : '';

/* On/Off label in the active Unraid language (no function defs in a .page). */
$lang = strtolower(substr((string)(isset($_SESSION['locale']) ? $_SESSION['locale'] : ''), 0, 2));
$onoff = array(
  'en'=>array('On','Off'),   'de'=>array('Ein','Aus'),   'nl'=>array('Aan','Uit'),
  'fr'=>array('Activé','Désactivé'), 'es'=>array('Activado','Desactivado'),
  'it'=>array('Attivo','Disattivo'), 'pt'=>array('Ligado','Desligado'),
  'ru'=>array('Вкл','Выкл'), 'uk'=>array('Увімк','Вимк'), 'bg'=>array('Вкл','Изкл'),
  'pl'=>array('Wł.','Wył.'), 'cs'=>array('Zap.','Vyp.'),
  'sv'=>array('På','Av'),    'da'=>array('Til','Fra'),    'no'=>array('På','Av'), 'nb'=>array('På','Av'),
  'fi'=>array('Päällä','Pois'), 'hu'=>array('Be','Ki'),   'ro'=>array('Pornit','Oprit'),
  'tr'=>array('Açık','Kapalı'), 'el'=>array('Ενεργό','Ανενεργό'),
  'zh'=>array('开','关'),     'ja'=>array('オン','オフ'),  'ko'=>array('켜짐','꺼짐'),
);
$lbl   = isset($onoff[$lang]) ? $onoff[$lang] : $onoff['en'];
$onTxt = $lbl[0]; $offTxt = $lbl[1];

/* Best-effort LAN IP for the status-page link — works even when the GUI is opened
   via the myunraid.net hostname, where location.hostname can't reach :PORT. */
$lanip = '';
$net = '/var/local/emhttp/network.ini';
if (is_file($net) && preg_match('/IPADDR(?::0)?\s*=\s*"?([0-9.]+)/', file_get_contents($net), $mip)) $lanip = $mip[1];
if ($lanip === '' && !empty($_SERVER['SERVER_ADDR'])) $lanip = $_SERVER['SERVER_ADDR'];
?>

<style>
  /* CC look: no dark backing sheet — the content sits on Unraid's own surface. A
     borderless, flat header (no box, no rule) and borderless cards that a lighter
     fill + a soft shadow — not a frame — set apart. */
  .sl-cfg{--card:#242424;--txt:#e6e6e6;--dim:#b4b4b4;--dim2:#8a8a8a;
    --line:#333;--line2:#3a3a3a;--inp:#1b1b1b;
    max-width:820px;margin:6px auto 0;color:var(--txt);
    font:14px/1.5 "Segoe UI",system-ui,-apple-system,sans-serif}
  .sl-cfg *{box-sizing:border-box}
  .sl-hd{display:flex;align-items:center;gap:15px;padding:0 2px 18px;margin-bottom:20px}
  .sl-hd .sl-logo{width:46px;height:46px;flex:none}
  .sl-hd .sl-ttl{font-size:21px;font-weight:600;letter-spacing:.2px}
  .sl-hd .sl-ttl b{font-weight:700}
  .sl-hd .sl-sub{margin-top:3px;color:var(--dim2);font-size:12.5px;max-width:660px}
  /* Header text follows Unraid's theme for readability (the logo is a fixed-colour image). */
  .Theme--white .sl-hd .sl-ttl,.Theme--azure .sl-hd .sl-ttl{color:#1c1c1c}
  .Theme--white .sl-hd .sl-sub,.Theme--azure .sl-hd .sl-sub{color:#666}

  .sl-card{background:var(--card);border:none;border-radius:12px;
    box-shadow:0 1px 3px rgba(0,0,0,.3);
    padding:6px 18px 16px;margin-bottom:16px}
  .sl-card > h3{display:flex;align-items:baseline;gap:10px;margin:14px 2px 14px;
    font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#cfcfcf;
    border-bottom:1px solid var(--line);padding-bottom:10px}
  .sl-card > h3 small{text-transform:none;letter-spacing:0;font-weight:400;color:var(--dim2);font-size:12px}

  .sl-row{display:grid;grid-template-columns:170px 1fr;gap:12px;align-items:center;padding:7px 2px}
  .sl-row > label{color:var(--dim);font-size:13px}
  .sl-row .sl-in{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .sl-cfg input[type=text],.sl-cfg input[type=password],.sl-cfg select{
    background:var(--inp);border:1px solid var(--line2);border-radius:7px;color:var(--txt);
    padding:7px 10px;font:13px/1.2 inherit;min-width:240px;outline:none}
  .sl-cfg input:focus,.sl-cfg select:focus{border-color:#6e6e6e}
  .sl-cfg input.sl-narrow{min-width:120px;width:120px}
  .sl-hint{color:var(--dim2);font-size:12px}
  .sl-cfg a{color:#8ab4f8;text-decoration:none}

  /* Match Unraid's native buttons via its theme vars (--button/--button-hover,
     --text/--border) so Apply + the helpers look native + hover like the rest of
     the GUI; fallbacks keep the dark look on themes/older builds without them. */
  .sl-btn{background:var(--button,#2a2a2a);border:1px solid var(--border,#3a3a3a);border-radius:6px;color:var(--text,#e6e6e6);
    padding:7px 14px;font:13px/1.2 inherit;cursor:pointer}
  .sl-btn:hover{background:var(--button-hover,#333);border-color:var(--border,#5a5a5a)}
  .sl-btn.sl-primary{font-weight:600}
  .sl-btn.sl-eye{padding:7px 10px;min-width:58px}
  .sl-res{font-size:12.5px}
  .sl-res.ok{color:#3fae6a}
  .sl-res.err{color:#d9534f}
  .sl-res.run{color:var(--dim)}
  .sl-actions{display:flex;gap:10px;margin:4px 2px 4px}

  .sl-switch{display:inline-flex;align-items:center;gap:10px;cursor:pointer;user-select:none}
  .sl-switch > input{position:absolute;opacity:0;width:0;height:0}
  .sl-track{position:relative;width:46px;height:24px;flex:none;border-radius:999px;
    background:#333;border:1px solid #444;transition:background .15s,border-color .15s}
  .sl-track::after{content:"";position:absolute;top:2px;left:2px;width:18px;height:18px;
    border-radius:50%;background:#8a8a8a;transition:transform .15s,background .15s}
  .sl-switch > input:checked + .sl-track{background:#2f9e54;border-color:#3fae6a}
  .sl-switch > input:checked + .sl-track::after{transform:translateX(22px);background:#f0f0f0}
  .sl-switch > input:focus-visible + .sl-track{box-shadow:0 0 0 2px #525252}
  .sl-state{font-size:13px;color:var(--dim);min-width:26px}
</style>

<div class="sl-cfg">

  <div class="sl-hd">
    <!-- Logo (user design): gold anchor + double ring (dark/white/dark). Fixed colours, reads
         on ANY Unraid theme — the white ring pops on the dark ones, the dark outer ring frames
         it on the light ones. Served as a file so it stays crisp. -->
    <img class="sl-logo" src="<?autov('/plugins/shiplog/images/shiplog-unraid.svg')?>" alt="ShipLog">
    <div>
      <div class="sl-ttl"><b>Ship</b>Log</div>
      <div class="sl-sub">Read-only update advisor — it never updates anything, it shows what changed and how risky, right in the Docker tab.</div>
    </div>
  </div>

  <form name="shiplog_settings" method="POST" action="/update.php" target="progressFrame">
    <input type="hidden" name="#file" value="shiplog/shiplog.cfg">
    <input type="hidden" name="#command" value="/usr/local/emhttp/plugins/shiplog/scripts/rc.shiplog">
    <input type="hidden" name="#arg[1]" value="restart">

    <div class="sl-card">
      <h3>Engine</h3>
      <div class="sl-row"><label>Enable</label><div class="sl-in">
        <label class="sl-switch">
          <input type="checkbox" id="sl-enable-cb" <?=$enable!=='false'?'checked':''?> onchange="slEnable(this)">
          <span class="sl-track"></span>
          <span class="sl-state" id="sl-enable-state"><?=htmlspecialchars($enable!=='false'?$onTxt:$offTxt)?></span>
        </label>
        <input type="hidden" name="ENABLE" id="sl-enable" value="<?=$enable!=='false'?'true':'false'?>"></div></div>
      <div class="sl-row"><label>Port</label><div class="sl-in">
        <input type="text" class="sl-narrow" name="PORT" value="<?=htmlspecialchars($port)?>">
        <span id="sl-statuslink" class="sl-hint"></span></div></div>
      <div class="sl-row"><label>Data directory</label><div class="sl-in">
        <input type="text" name="DATA_DIR" value="<?=htmlspecialchars($ddir)?>">
        <span class="sl-hint">SQLite cache — keep on appdata, not the flash</span></div></div>
      <div class="sl-row"><label>Poll interval</label><div class="sl-in">
        <input type="text" class="sl-narrow" name="POLL_INTERVAL" value="<?=htmlspecialchars($poll)?>">
        <span class="sl-hint">Go duration: 1h, 6h, 24h</span></div></div>
    </div>

    <div class="sl-card">
      <h3>Registry access <small>Optional — both raise rate limits so ShipLog can read versions &amp; changelogs for more of your containers. Leave empty to stay anonymous.</small></h3>
      <div class="sl-row"><label>GitHub token</label><div class="sl-in">
        <input type="password" id="sl-GITHUB_TOKEN" name="GITHUB_TOKEN" value="<?=htmlspecialchars($ghtok)?>">
        <button type="button" class="sl-btn sl-eye" onclick="slToggle('sl-GITHUB_TOKEN',this)">Show</button>
        <button type="button" class="sl-btn" onclick="slCheckGitHub()">Check</button>
        <span id="sl-gh-result" class="sl-res"></span>
        <span class="sl-hint">Reads release notes from GitHub. Anonymous GitHub allows only ~60 requests/hour — with many containers that runs out fast and changelogs come back empty. A classic <a href="https://github.com/settings/tokens" target="_blank">Personal Access Token</a> (no scopes needed) raises it to ~5000/hour.</span></div></div>
      <div class="sl-row"><label>Docker Hub user</label><div class="sl-in">
        <input type="text" name="DOCKERHUB_USERNAME" value="<?=htmlspecialchars($dhuser)?>" placeholder="your Docker Hub username"></div></div>
      <div class="sl-row"><label>Docker Hub token</label><div class="sl-in">
        <input type="password" id="sl-DOCKERHUB_TOKEN" name="DOCKERHUB_TOKEN" value="<?=htmlspecialchars($dhtok)?>">
        <button type="button" class="sl-btn sl-eye" onclick="slToggle('sl-DOCKERHUB_TOKEN',this)">Show</button>
        <button type="button" class="sl-btn" onclick="slCheckDockerHub()">Check</button>
        <span id="sl-dh-result" class="sl-res"></span>
        <span class="sl-hint">Checks the newest version + digest of <code>docker.io</code> images. Anonymous Docker Hub is rate-limited per IP — with many images that throttles, so those show an update without a version number. A free <a href="https://app.docker.com/settings/personal-access-tokens" target="_blank">Docker Hub access token</a> (read-only) lifts the limit. Username + token, both required.</span></div></div>
    </div>

    <div class="sl-card">
      <h3>AI summaries <small>Optional — Ollama condenses each changelog into "what changes / breaking / risk".</small></h3>
      <div class="sl-row"><label>Ollama URL</label><div class="sl-in">
        <input type="text" name="OLLAMA_URL" value="<?=htmlspecialchars($ourl)?>" placeholder="http://127.0.0.1:11434">
        <button type="button" class="sl-btn" onclick="slDetectOllama()">Autodetect</button>
        <span class="sl-hint">Probes common local Ollama ports and fills this in.</span></div></div>
      <div class="sl-row"><label>Ollama model</label><div class="sl-in">
        <input type="text" name="OLLAMA_MODEL" value="<?=htmlspecialchars($omodel)?>" placeholder="llama3.1">
        <button type="button" class="sl-btn" onclick="slCheckOllama()">Check</button>
        <span id="sl-ollama-result" class="sl-res"></span></div></div>
    </div>

    <div class="sl-card">
      <h3>Notifications <small>Optional — Matrix message when a new update is first seen.</small></h3>
      <div class="sl-row"><label>Matrix homeserver</label><div class="sl-in">
        <input type="text" name="MATRIX_HOMESERVER" value="<?=htmlspecialchars($mhs)?>" placeholder="https://matrix.example.com"></div></div>
      <div class="sl-row"><label>Matrix token</label><div class="sl-in">
        <input type="password" id="sl-MATRIX_TOKEN" name="MATRIX_TOKEN" value="<?=htmlspecialchars($mtok)?>">
        <button type="button" class="sl-btn sl-eye" onclick="slToggle('sl-MATRIX_TOKEN',this)">Show</button></div></div>
      <div class="sl-row"><label>Matrix room</label><div class="sl-in">
        <input type="text" name="MATRIX_ROOM" value="<?=htmlspecialchars($mroom)?>" placeholder="!roomid:server  or  #alias:server">
        <button type="button" class="sl-btn" onclick="slCheckMatrix()">Check</button>
        <span id="sl-matrix-result" class="sl-res"></span></div></div>
    </div>

    <div class="sl-actions">
      <input type="submit" name="#apply" class="sl-btn sl-primary" value="Apply">
      <input type="button" class="sl-btn" value="Done" onclick="done()">
    </div>
  </form>
</div>

<script>
(function () {
  var port = "<?=htmlspecialchars($port)?>";
  var host = <?=json_encode($lanip)?> || location.hostname;
  var a = document.getElementById("sl-statuslink");
  if (!a) return;
  a.innerHTML = '<span class="sl-res run">checking engine…</span>';
  fetch("/plugins/shiplog/server/status.php", { headers: { Accept: "application/json" } })
    .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }, function () { return { ok: false, d: null }; }); })
    .then(function (res) {
      if (res.ok && Array.isArray(res.d)) {
        var n = res.d.length;
        a.innerHTML = '<span class="sl-res ok">✓ engine running · ' + n + ' container' + (n === 1 ? '' : 's') + ' tracked</span>' +
          ' <span class="sl-hint">status page: <a href="http://' + host + ':' + port + '/" target="_blank" rel="noopener">open ↗</a></span>';
      } else {
        a.innerHTML = '<span class="sl-res err">✗ engine not reachable</span> <span class="sl-hint">— enable it above + Apply, then reload</span>';
      }
    })
    .catch(function () { a.innerHTML = '<span class="sl-res err">✗ engine not reachable</span>'; });
})();
var SL_ON = <?=json_encode($onTxt)?>, SL_OFF = <?=json_encode($offTxt)?>;
function slEnable(cb) {
  document.getElementById('sl-enable').value = cb.checked ? 'true' : 'false';
  document.getElementById('sl-enable-state').textContent = cb.checked ? SL_ON : SL_OFF;
  slFire(document.getElementById('sl-enable'));
}
// Unraid only un-greys Apply when a field fires change/input. A programmatic
// value change (autodetect, the toggle's hidden field) must announce itself.
function slFire(el) {
  if (!el) return;
  el.dispatchEvent(new Event('input', { bubbles: true }));
  el.dispatchEvent(new Event('change', { bubbles: true }));
}
function slCheck(elId, url) {
  var out = document.getElementById(elId);
  out.className = 'sl-res run'; out.textContent = 'Checking…';
  fetch(url)
    .then(function (r) { return r.json(); })
    .then(function (d) { out.className = 'sl-res ' + (d.ok ? 'ok' : 'err'); out.textContent = (d.ok ? '✓ ' : '✗ ') + d.message; })
    .catch(function (e) { out.className = 'sl-res err'; out.textContent = '✗ ' + e; });
}
function slVal(n) { return (document.querySelector('[name=' + n + ']') || {}).value || ''; }
function slToggle(id, btn) {
  var i = document.getElementById(id);
  if (!i) return;
  if (i.type === 'password') { i.type = 'text'; btn.textContent = 'Hide'; }
  else { i.type = 'password'; btn.textContent = 'Show'; }
}
function slCheckDockerHub() {
  slCheck('sl-dh-result', '/plugins/shiplog/server/dockerhub-check.php?user=' +
    encodeURIComponent(slVal('DOCKERHUB_USERNAME')) + '&token=' + encodeURIComponent(slVal('DOCKERHUB_TOKEN')));
}
function slCheckOllama() {
  slCheck('sl-ollama-result', '/plugins/shiplog/server/ollama-check.php?url=' +
    encodeURIComponent(slVal('OLLAMA_URL')) + '&model=' + encodeURIComponent(slVal('OLLAMA_MODEL')));
}
function slCheckMatrix() {
  slCheck('sl-matrix-result', '/plugins/shiplog/server/matrix-check.php?hs=' +
    encodeURIComponent(slVal('MATRIX_HOMESERVER')) + '&token=' + encodeURIComponent(slVal('MATRIX_TOKEN')) +
    '&room=' + encodeURIComponent(slVal('MATRIX_ROOM')));
}
function slCheckGitHub() {
  slCheck('sl-gh-result', '/plugins/shiplog/server/github-check.php?token=' + encodeURIComponent(slVal('GITHUB_TOKEN')));
}
function slDetectOllama() {
  var out = document.getElementById('sl-ollama-result');
  out.className = 'sl-res run'; out.textContent = 'Detecting…';
  fetch('/plugins/shiplog/server/ollama-detect.php?url=' + encodeURIComponent(slVal('OLLAMA_URL')))
    .then(function (r) { return r.json(); })
    .then(function (d) {
      out.className = 'sl-res ' + (d.ok ? 'ok' : 'err');
      out.textContent = (d.ok ? '✓ ' : '✗ ') + d.message;
      if (d.ok && d.url) {
        var u = document.querySelector('[name=OLLAMA_URL]'); if (u) { u.value = d.url; slFire(u); }
        var m = document.querySelector('[name=OLLAMA_MODEL]'); if (m && !m.value && d.models && d.models.length) { m.value = d.models[0]; slFire(m); }
      }
    })
    .catch(function (e) { out.className = 'sl-res err'; out.textContent = '✗ ' + e; });
}
</script>
