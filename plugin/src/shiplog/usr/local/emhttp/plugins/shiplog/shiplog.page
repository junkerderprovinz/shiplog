  .sl-track{position:relative;width:46px;height:24px;flex:none;border-radius:999px;
    background:#333;border:1px solid #444;transition:background .15s,border-color .15s}
  .sl-track::after{content:"";position:absolute;top:2px;left:2px;width:18px;height:18px;
    border-radius:50%;background:#8a8a8a;transition:transform .15s,background .15s}
  /* checked = Unraid's orange accent */
  .sl-switch > input:checked + .sl-track{background:#ff8c2f;border-color:#ff8c2f}
  .sl-switch > input:checked + .sl-track::after{transform:translateX(22px);background:#fff}
  .sl-switch > input:focus-visible + .sl-track{box-shadow:0 0 0 2px #525252}
  .sl-state{font-size:13px;color:var(--dim);min-width:26px}

  /* Tabs (CC-style): a flat row of buttons; the active one carries Unraid's orange
