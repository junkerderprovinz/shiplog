#!/bin/bash
# ShipLog engine daemon control (start/stop/restart/status).
# The engine is the same Go binary as the container image; here it runs as a
# plain host daemon started by the plugin. Read-only Docker socket; never writes.

NAME="shiplog"
BIN="/usr/local/emhttp/plugins/${NAME}/bin/${NAME}"
CFG="/boot/config/plugins/${NAME}/${NAME}.cfg"
PIDFILE="/var/run/${NAME}.pid"
LOG="/var/log/${NAME}.log"

# Defaults — overridden by the cfg (written by the settings page as KEY="value").
ENABLE="true"
PORT="8484"
DATA_DIR="/mnt/user/appdata/shiplog"
DOCKER_SOCKET="/var/run/docker.sock"
POLL_INTERVAL=""
GITHUB_TOKEN=""
OLLAMA_URL=""
OLLAMA_MODEL=""
MATRIX_HOMESERVER=""
MATRIX_TOKEN=""
MATRIX_ROOM=""
AUTOUPDATE_ENABLED="false"
AUTOUPDATE_LEVEL="off"
AUTOUPDATE_DIGEST="false"
AUTOUPDATE_DRYRUN="false"
AUTOUPDATE_SCHED_MODE="off"
AUTOUPDATE_SCHED_TIME="04:00"
AUTOUPDATE_SCHED_EVERY="6"
AUTOUPDATE_EXCLUDE_WORDS=""
[ -f "$CFG" ] && . "$CFG"

is_running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; }

start() {
  if [ "$ENABLE" = "false" ]; then echo "shiplog: disabled in settings"; return 0; fi
  if is_running; then echo "shiplog: already running (pid $(cat "$PIDFILE"))"; return 0; fi
  # Do NOT start until DATA_DIR sits on a real, mounted filesystem. At boot the
  # plugin installs (and the .plg runs this) BEFORE the array/pools are mounted,
  # so DATA_DIR would resolve to the root tmpfs: the SQLite version-memory gets
  # wiped on every reboot, and pre-creating /mnt/user/... can even stop the
  # user-share (shfs) from mounting. Defer — event/started restarts us once the
  # array is up and DATA_DIR is on its real (non-root) filesystem.
  probe="$DATA_DIR"
  while [ ! -e "$probe" ] && [ "$probe" != "/" ]; do probe=$(dirname "$probe"); done
  if [ "$(stat -c %d "$probe" 2>/dev/null)" = "$(stat -c %d / 2>/dev/null)" ]; then
    echo "shiplog: $DATA_DIR still on the root filesystem (array/pool not mounted yet) — deferring until array-start"
    return 0
  fi
  # The package may arrive without the exec bit (e.g. built on a filesystem with
  # no Unix mode bits) — enforce it here so the daemon is independent of that.
  [ -f "$BIN" ] && chmod +x "$BIN" 2>/dev/null
  if [ ! -x "$BIN" ]; then echo "shiplog: binary missing or not executable at $BIN"; return 1; fi
  mkdir -p "$DATA_DIR"
  export PORT DATA_DIR DOCKER_SOCKET POLL_INTERVAL GITHUB_TOKEN \
         OLLAMA_URL OLLAMA_MODEL MATRIX_HOMESERVER MATRIX_TOKEN MATRIX_ROOM \
         AUTOUPDATE_ENABLED AUTOUPDATE_LEVEL AUTOUPDATE_DIGEST AUTOUPDATE_DRYRUN \
         AUTOUPDATE_SCHED_MODE AUTOUPDATE_SCHED_TIME AUTOUPDATE_SCHED_EVERY \
         AUTOUPDATE_EXCLUDE_WORDS
  setsid "$BIN" >>"$LOG" 2>&1 &
  echo $! >"$PIDFILE"
  # log the start line to the daemon log only, NOT stdout: Unraid mirrors an rc script's stdout
  # during the array-start event into the native footer status bar, where "shiplog: started …"
  # cluttered the strip (user call — remove it at the source). Errors above still surface.
  echo "shiplog: started (pid $(cat "$PIDFILE"), port $PORT)" >>"$LOG"
}

stop() {
  local pid=""
  [ -f "$PIDFILE" ] && pid=$(cat "$PIDFILE" 2>/dev/null)
  [ -n "$pid" ] && kill "$pid" 2>/dev/null
  pkill -f "$BIN" 2>/dev/null
  # The engine shuts down gracefully (can take a few seconds); wait until it is
  # really gone so a following start can bind the port — a fixed sleep raced the
  # graceful shutdown and left the new instance unable to listen.
  for _ in $(seq 1 20); do
    pgrep -f "$BIN" >/dev/null 2>&1 || break
    sleep 0.5
  done
  pkill -9 -f "$BIN" 2>/dev/null  # last resort if it didn't exit in time
  rm -f "$PIDFILE"
  echo "shiplog: stopped"
}

status() {
  if is_running; then echo "shiplog: running (pid $(cat "$PIDFILE"), port $PORT)";
  else echo "shiplog: stopped"; fi
}

case "$1" in
  start)   start ;;
  stop)    stop ;;
  restart) stop; start ;;
  status)  status ;;
  *) echo "usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
